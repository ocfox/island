{
  "uid": "aqua",
  "title": "Aqua",
  "tags": ["aqua"],
  "timezone": "browser",
  "schemaVersion": 41,
  "version": 2,
  "refresh": "5m",
  "time": { "from": "now-24h", "to": "now" },
  "panels": [
    {
      "id": 1,
      "type": "timeseries",
      "title": "Active time by app",
      "gridPos": { "x": 0, "y": 0, "w": 24, "h": 10 },
      "datasource": { "type": "prometheus", "uid": "VictoriaMetrics" },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "VictoriaMetrics" },
          "expr": "aqua_active_ms{agent_id=\"gallery\"}",
          "legendFormat": "{{app_id}}",
          "instant": false
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ms",
          "custom": { "drawStyle": "bars", "fillOpacity": 60, "stacking": { "mode": "normal" } }
        },
        "overrides": []
      },
      "options": {
        "tooltip": { "mode": "multi" },
        "legend": { "showLegend": true, "displayMode": "table", "placement": "right", "calcs": ["sum"] }
      }
    },
    {
      "id": 2,
      "type": "table",
      "title": "Top applications",
      "gridPos": { "x": 0, "y": 10, "w": 24, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "VictoriaMetrics" },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "VictoriaMetrics" },
          "expr": "sort_desc(sum by (app_id) (aqua_active_ms{agent_id=\"gallery\"}))",
          "instant": true,
          "legendFormat": "{{app_id}}"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "ms", "custom": { "align": "auto" } },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "app_id" },
            "properties": [{ "id": "custom.width", "value": 300 }]
          },
          {
            "matcher": { "id": "byName", "options": "Value" },
            "properties": [
              { "id": "displayName", "value": "Active time" },
              { "id": "custom.displayMode", "value": "basic" }
            ]
          }
        ]
      },
      "options": { "showHeader": true },
      "transformations": [
        { "id": "labelsToFields", "options": { "valueLabel": "app_id" } },
        { "id": "merge", "options": {} },
        { "id": "sortBy", "options": { "fields": [{ "displayName": "Active time", "desc": true }] } }
      ]
    },
    {
      "id": 3,
      "type": "state-timeline",
      "title": "Activity timeline",
      "gridPos": { "x": 0, "y": 18, "w": 24, "h": 6 },
      "datasource": { "type": "prometheus", "uid": "VictoriaMetrics" },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "VictoriaMetrics" },
          "expr": "aqua_online{agent_id=\"gallery\"}",
          "legendFormat": "{{state}}",
          "instant": false
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": { "lineWidth": 0, "fillOpacity": 70 },
          "mappings": [
            {
              "type": "value",
              "options": {
                "idle": { "text": "idle", "color": "#6c757d", "index": 0 }
              }
            }
          ],
          "color": { "mode": "palette-classic" }
        },
        "overrides": []
      },
      "options": {
        "mergeValues": true,
        "showValue": "auto",
        "alignValue": "center",
        "rowHeight": 0.9,
        "legend": { "showLegend": true, "displayMode": "list", "placement": "bottom" },
        "tooltip": { "mode": "single" }
      }
    }
  ]
}
